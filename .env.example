# --- GEOSPATIAL CONFIGURATION ---
# The reference center point for the facility (e.g., T.E. Maxson center)
ORIGIN_LATITUDE=35.0456
ORIGIN_LONGITUDE=-90.0489

# --- DIRECTORY PATHS ---
# Where the raw .shp files live
SHP_SOURCE_DIR="./shp_data"

# Output destinations
GEOJSON_OUT_DIR="./gis-output/geojson/"
DXF_OUT_DIR="./gis-output/dxf/"
KML_OUT_DIR="./gis-output/kml/"
CSV_OUT_DIR="./gis-output/csv/"

# --- CAD SPECIFIC ---
# Coordinate system for DXF (Default: TN State Plane West - Feet)
# Use EPSG:2274 for Tennessee West
DXF_SRS="EPSG:2274"
